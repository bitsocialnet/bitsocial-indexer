# ─── bitsocial-indexer ────────────────────────────────────────────────────
# Copy to .env in server/ (and/or webui/) and adjust. Nothing here is required;
# the defaults run an empty, local-only indexer.

# ── server/ ──────────────────────────────────────────────────────────────
PORT=4000
HOST=0.0.0.0

# SQLite database file. Use ":memory:" for an ephemeral demo.
DB_PATH=./data/indexer.db

# The bitsocial-cli daemon to crawl through (PKC RPC over WebSocket).
PKC_RPC_URL=ws://localhost:9138

# WHAT TO INDEX — both empty by default (the indexer then serves nothing).
#   COMMUNITIES        comma-separated addresses
#   COMMUNITIES_SOURCE url/path to a JSON array of addresses (e.g. a directory)
COMMUNITIES=
COMMUNITIES_SOURCE=

# How often (ms) to re-crawl each configured community.
CRAWL_INTERVAL_MS=60000

# Load demo communities + posts on boot (same data as `npm run seed`).
SEED_DEMO=false

# Branding / SEO for the bundled UI + sitemap.
SITE_NAME=Bitsocial Indexer
SITE_URL=http://localhost:4000

# CORS allow-list for the API ("*" = any origin).
CORS_ORIGIN=*

# ── webui/ ───────────────────────────────────────────────────────────────
# Where the web UI reads the API from (server-side fetch).
INDEXER_API=http://localhost:4000
